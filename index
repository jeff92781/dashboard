    const fmtBRL = new Intl.NumberFormat("pt-BR", { style: "currency", currency: "BRL", maximumFractionDigits: 0 });
    const fmtBRLFull = new Intl.NumberFormat("pt-BR", { style: "currency", currency: "BRL", minimumFractionDigits: 2, maximumFractionDigits: 2 });
    const fmtPct = new Intl.NumberFormat("pt-BR", { minimumFractionDigits: 1, maximumFractionDigits: 1 });

    function parseBRNumber(value){
      if(value === null || value === undefined || value === "") return 0;
      if(typeof value === "number") return Number.isFinite(value) ? value : 0;
      let s = String(value).trim().replace(/R\$/g, "").replace(/\s/g, "");
      if(!s || s.toLowerCase() === "nan") return 0;
      if(s.includes(",")) s = s.replace(/\./g, "").replace(",", ".");
      const n = Number(s);
      return Number.isFinite(n) ? n : 0;
    }

    function parseDate(value){
      if(!value) return null;
      if(value instanceof Date && !isNaN(value)) return value;
      if(typeof value === "number"){
        const utc = Math.round((value - 25569) * 86400 * 1000);
        return new Date(utc);
      }
      const s = String(value).trim();
      let m = s.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
      if(m) return new Date(Number(m[3]), Number(m[2])-1, Number(m[1]));
      m = s.match(/^(\d{4})-(\d{1,2})-(\d{1,2})/);
      if(m) return new Date(Number(m[1]), Number(m[2])-1, Number(m[3]));
      const d = new Date(s);
      return isNaN(d) ? null : d;
    }

    function toISODate(d){
      const pad = n => String(n).padStart(2,"0");
      return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}`;
    }

    function monthKeyFromDate(d){ return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,"0")}`; }
    function monthLabel(key){
      const [y,m] = key.split("-").map(Number);
      return `${MONTHS[m-1]}/${String(y).slice(-2)}`;
    }

    function normalizeImportedRows(jsonRows){
      const result = [];
      for(const row of jsonRows){
        const keys = Object.keys(row);
        const dateKey = keys.find(k => String(k).trim().toLowerCase() === "data") || keys.find(k => /data/i.test(k));
        const date = parseDate(row[dateKey]);
        if(!date) continue;
        const out = { date: toISODate(date) };
        for(const code of BRANCH_ORDER){
          const foundKey = keys.find(k => String(k).includes(code)) || BRANCHES[code].full;
          out[code] = parseBRNumber(row[foundKey]);
        }
        result.push(out);
      }
      return result;
    }

    function parseTextTable(text){
      const lines = text.trim().split(/\r?\n/).filter(Boolean);
      if(!lines.length) return [];
      const sep = lines[0].includes("\t") ? "\t" : ";";
      const headers = lines[0].split(sep).map(h => h.trim() || "col");
      const rows = lines.slice(1).map(line => {
        const cells = line.split(sep);
        const obj = {};
        headers.forEach((h,i) => obj[h] = cells[i] ?? "");
        return obj;
      });
      return normalizeImportedRows(rows);
    }

    function getFilteredRows(){
      const start = document.getElementById("startDate").value;
      const end = document.getElementById("endDate").value;
      return rawRows.filter(r => (!start || r.date >= start) && (!end || r.date <= end));
    }

    function aggregateMonthly(rows){
      const map = new Map();
      for(const r of rows){
        const d = parseDate(r.date);
        if(!d) continue;
        const key = monthKeyFromDate(d);
        if(!map.has(key)) map.set(key, { key, label: monthLabel(key), "0104":0, "0109":0, "0114":0, "0116":0 });
        const m = map.get(key);
        for(const code of BRANCH_ORDER) m[code] += Number(r[code] || 0);
      }
      return [...map.values()].sort((a,b) => a.key.localeCompare(b.key));
    }

    function totalsByBranch(rows){
      const totals = {"0104":0,"0109":0,"0114":0,"0116":0};
      for(const r of rows){ for(const code of BRANCH_ORDER) totals[code] += Number(r[code] || 0); }
      return totals;
    }

    function setupDateFilters(){
      if(!rawRows.length) return;
      const dates = rawRows.map(r => r.date).sort();
      const min = dates[0], max = dates[dates.length-1];
      const start = document.getElementById("startDate"), end = document.getElementById("endDate");
      start.min = min; start.max = max; end.min = min; end.max = max;
      start.value = min; end.value = max;
    }

    function updateDashboard(){
      const rows = getFilteredRows();
      const monthly = aggregateMonthly(rows);
      const activeCodes = getSelectedBranches();
      const totals = totalsByBranch(rows);
      const totalSelected = activeCodes.reduce((s,c)=>s+totals[c],0);
      const monthsCount = monthly.length;
      const uniqueDays = new Set(rows.map(r => r.date)).size;

      document.getElementById("periodLabel").textContent = rows.length ? `${formatDateBR(document.getElementById("startDate").value)} a ${formatDateBR(document.getElementById("endDate").value)}` : "Sem dados no período selecionado";
      document.getElementById("totalRevenue").textContent = fmtBRL.format(totalSelected);
      document.getElementById("totalFoot").textContent = "";
      document.getElementById("avgMonthly").textContent = fmtBRL.format(monthsCount ? totalSelected / monthsCount : 0);
      document.getElementById("avgFoot").textContent = "";
      document.getElementById("avgDaily").textContent = fmtBRL.format(uniqueDays ? totalSelected / uniqueDays : 0);
      document.getElementById("dailyFoot").textContent = "";

      renderLine(monthly, activeCodes);
      renderDonut(totals, totalSelected, activeCodes);
    }

    function formatDateBR(iso){
      if(!iso) return "";
      const [y,m,d] = iso.split("-");
      return `${d}/${m}/${y}`;
    }

    function renderLine(monthly, activeCodes){
      document.getElementById("lineInfo").textContent = `${monthly.length} meses • ${activeCodes.length} filiais`;
      const series = activeCodes.map(code => ({
