    function renderDonutLegend(totals, totalSelected, activeCodes){
      const el = document.getElementById("donutLegend");
      el.innerHTML = activeCodes.map(code => {
        const value = totals[code] || 0;
        const pct = totalSelected ? (value / totalSelected) * 100 : 0;
        return `<div class="legend-item" data-branch="${code}">
          <div class="legend-name"><span class="dot" style="background:${BRANCHES[code].color}"></span>${BRANCHES[code].label}</div>
          <div class="legend-value">${fmtBRL.format(value)}</div>
          <div class="legend-pct">${fmtPct.format(pct)}%</div>
        </div>`;
      }).join("");
      el.querySelectorAll(".legend-item").forEach(item => {
        item.addEventListener("click", () => { setSelectedBranches([item.dataset.branch]); updateDashboard(); });
        item.style.cursor = "pointer";
      });
    }

    function getSelectedBranches(){
      const checked = [...document.querySelectorAll('#branchMenu input[type="checkbox"]:checked')].map(i => i.value);
      return checked.length ? checked : BRANCH_ORDER.slice();
    }

    function setSelectedBranches(codes){
      document.querySelectorAll('#branchMenu input[type="checkbox"]').forEach(input => input.checked = codes.includes(input.value));
      updateBranchButton();
    }

    function updateBranchButton(){
      const selected = getSelectedBranches();
      const btn = document.getElementById("branchBtn");
      if(selected.length === BRANCH_ORDER.length) btn.textContent = "Todas as filiais";
      else if(selected.length === 1) btn.textContent = BRANCHES[selected[0]].label;
      else btn.textContent = `${selected.length} filiais selecionadas`;
    }

    function bestDayOfMonth(rows, activeCodes){
      const byDay = new Map();
      for(const r of rows){
        const d = parseDate(r.date);
        if(!d) continue;
        const day = d.getDate();
        const value = activeCodes.reduce((s,c)=>s+Number(r[c] || 0),0);
        byDay.set(day, (byDay.get(day) || 0) + value);
      }
      let best = {day:null, value:0};
      byDay.forEach((value, day) => { if(value > best.value) best = {day, value}; });
      return best;
    }

    function compactBRL(value){
      const abs = Math.abs(value || 0);
      if(abs >= 1_000_000) return `R$ ${(value/1_000_000).toLocaleString("pt-BR",{maximumFractionDigits:1})} mi`;
      if(abs >= 1_000) return `R$ ${(value/1_000).toLocaleString("pt-BR",{maximumFractionDigits:0})} mil`;
      return fmtBRL.format(value || 0);
    }

    document.getElementById("clearBtn").addEventListener("click", () => { setupDateFilters(); setSelectedBranches(BRANCH_ORDER.slice()); updateDashboard(); });
    document.getElementById("startDate").addEventListener("change", updateDashboard);
    document.getElementById("endDate").addEventListener("change", updateDashboard);
    document.getElementById("branchBtn").addEventListener("click", () => document.getElementById("branchMulti").classList.toggle("open"));
    document.getElementById("selectAllBranches").addEventListener("click", () => { setSelectedBranches(BRANCH_ORDER.slice()); updateDashboard(); });
    document.getElementById("clearBranches").addEventListener("click", () => { setSelectedBranches([]); updateDashboard(); });
    document.querySelectorAll('#branchMenu input[type="checkbox"]').forEach(input => input.addEventListener("change", () => { updateBranchButton(); updateDashboard(); }));
    document.addEventListener("click", (e) => { if(!document.getElementById("branchMulti").contains(e.target)) document.getElementById("branchMulti").classList.remove("open"); });

    setupDateFilters();
    updateBranchButton();
    updateDashboard();
  </script>
</body>
</html>
