<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard Desempenho das Filiais</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
  <style>
    :root{
      --bg:#07111f;
      --bg2:#0a1c31;
      --panel:#10253d;
      --panel2:#0d1d31;
      --stroke:#25486c;
      --stroke2:#35638d;
      --text:#f4f8ff;
      --muted:#8fb4dc;
      --blue1:#38bdf8;
      --blue2:#0ea5e9;
      --blue3:#2563eb;
      --blue4:#93c5fd;
      --blue5:#60a5fa;
      --cyan:#67e8f9;
      --shadow: 0 20px 60px rgba(0,0,0,.35);
      --radius: 22px;
    }
    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      font-family:Inter,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
      background:
        radial-gradient(circle at top left, rgba(56,189,248,.18), transparent 28%),
        radial-gradient(circle at 80% 10%, rgba(37,99,235,.16), transparent 24%),
        linear-gradient(180deg,#061020 0%, #08182a 45%, #06101d 100%);
      color:var(--text);
      min-height:100vh;
    }
    .topbar{
      padding:28px 32px 22px;
      border-bottom:1px solid rgba(96,165,250,.18);
      background:rgba(5,12,24,.74);
      backdrop-filter:blur(18px);
      position:sticky;top:0;z-index:20;
    }
    .header-row{display:flex;align-items:center;justify-content:space-between;gap:22px;margin-bottom:22px}
    .brand{display:flex;align-items:center;gap:16px;min-width:0}
    .logo{
      width:64px;height:64px;border-radius:20px;
      display:grid;place-items:center;
      background:linear-gradient(135deg,#1d4ed8 0%,#38bdf8 55%,#0f766e 100%);
      box-shadow:0 14px 35px rgba(14,165,233,.25);
      font-weight:900;font-size:32px;color:white;
    }
    .kicker{font-size:13px;letter-spacing:.26em;text-transform:uppercase;color:#7dd3fc;font-weight:900;margin-bottom:4px}
    h1{margin:0;font-size:clamp(25px,2.2vw,38px);line-height:1.08;font-weight:900;letter-spacing:-.04em}
    .subtitle{margin:8px 0 0;color:var(--muted);font-weight:600;font-size:15px}
    .actions{display:flex;gap:12px;align-items:center;flex-wrap:wrap;justify-content:flex-end}
    button,.file-btn{
      border:1px solid rgba(125,211,252,.35);
      background:linear-gradient(180deg,rgba(28,64,105,.92),rgba(14,30,52,.92));
      color:var(--text);font-weight:900;border-radius:16px;
      padding:14px 18px;cursor:pointer;box-shadow:inset 0 1px 0 rgba(255,255,255,.08);
      transition:.2s ease;white-space:nowrap;
    }
    button:hover,.file-btn:hover{transform:translateY(-1px);border-color:#7dd3fc;background:linear-gradient(180deg,rgba(37,99,235,.45),rgba(14,30,52,.95))}
    input[type=file]{display:none}
    .filters{display:grid;grid-template-columns:1.15fr 1.15fr;gap:14px;max-width:980px}
    .filter-card{
      background:linear-gradient(135deg,rgba(16,37,61,.96),rgba(9,24,42,.95));
      border:1px solid rgba(96,165,250,.22);border-radius:var(--radius);
      padding:16px;box-shadow:var(--shadow);
    }
    .filter-card label{display:block;color:#bed6f2;text-transform:uppercase;font-weight:900;letter-spacing:.08em;font-size:13px;margin-bottom:10px}
    .range-duo{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    input,select{
      width:100%;border:1px solid rgba(125,211,252,.32);
      border-radius:15px;background:#09172a;color:var(--text);padding:15px 16px;
      outline:none;font-weight:800;font-size:15px;
    }
    input:focus,select:focus{border-color:#7dd3fc;box-shadow:0 0 0 4px rgba(56,189,248,.08)}

    select{cursor:pointer;appearance:none;background-image:linear-gradient(45deg,transparent 50%,#93c5fd 50%),linear-gradient(135deg,#93c5fd 50%,transparent 50%);background-position:calc(100% - 22px) 50%,calc(100% - 16px) 50%;background-size:6px 6px,6px 6px;background-repeat:no-repeat;padding-right:44px}
    .multi-select{position:relative}
    .multi-btn{
      width:100%;min-height:51px;border:1px solid rgba(125,211,252,.32);border-radius:15px;background:#09172a;color:var(--text);
      padding:15px 44px 15px 16px;display:flex;align-items:center;justify-content:space-between;gap:12px;cursor:pointer;font-weight:900;font-size:15px;text-align:left;
      background-image:linear-gradient(45deg,transparent 50%,#93c5fd 50%),linear-gradient(135deg,#93c5fd 50%,transparent 50%);background-position:calc(100% - 22px) 50%,calc(100% - 16px) 50%;background-size:6px 6px,6px 6px;background-repeat:no-repeat;
    }
    .multi-btn:focus{outline:none;border-color:#7dd3fc;box-shadow:0 0 0 4px rgba(56,189,248,.08)}
    .multi-menu{display:none;position:absolute;left:0;right:0;top:calc(100% + 8px);z-index:30;background:#07182b;border:1px solid rgba(125,211,252,.36);border-radius:16px;padding:8px;box-shadow:0 18px 45px rgba(0,0,0,.45)}
    .multi-select.open .multi-menu{display:grid;gap:6px}
    .multi-option{display:flex;align-items:center;gap:10px;padding:11px 10px;border-radius:12px;color:#dbeafe;font-weight:900;cursor:pointer}
    .multi-option:hover{background:rgba(56,189,248,.10)}
    .multi-option input{width:17px;height:17px;accent-color:#38bdf8;cursor:pointer}
    .multi-actions{display:flex;gap:8px;border-top:1px solid rgba(125,211,252,.18);padding-top:8px;margin-top:4px}
    .multi-actions button{padding:9px 10px;border-radius:11px;font-size:12px;flex:1}

    main{padding:28px 32px 46px}
    .section-title{margin:0 0 8px;font-size:30px;font-weight:900;letter-spacing:-.04em}
    .period-label{color:#93c5fd;font-weight:600;margin-bottom:22px}
    .cards{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:18px}
    .metric{
      position:relative;overflow:hidden;min-height:148px;
      background:linear-gradient(135deg,rgba(17,39,63,.96),rgba(8,22,39,.98));
      border:1px solid rgba(96,165,250,.23);border-radius:var(--radius);padding:22px;
      box-shadow:var(--shadow);
    }
    .metric:after{
      content:"";position:absolute;right:-45px;top:-55px;width:150px;height:150px;border-radius:50%;
      background:radial-gradient(circle,rgba(56,189,248,.24),transparent 62%);
    }
    .metric .tag{
      position:absolute;right:18px;top:18px;border:1px solid rgba(125,211,252,.32);
      background:rgba(14,165,233,.16);border-radius:16px;padding:12px 14px;color:#7dd3fc;font-weight:900;
    }
    .metric-title{text-transform:uppercase;color:#c7ddf6;letter-spacing:.08em;font-size:13px;font-weight:900;margin-bottom:16px;position:relative;z-index:1}
    .metric-value{font-size:clamp(26px,2.4vw,40px);font-weight:900;letter-spacing:-.05em;margin-bottom:8px;position:relative;z-index:1}
    .metric-foot{color:#67e8f9;font-weight:900;font-size:14px;position:relative;z-index:1}
    .grid{display:grid;grid-template-columns:minmax(0,1.55fr) minmax(360px,.85fr);gap:18px;align-items:stretch}
    .panel{
      background:linear-gradient(135deg,rgba(15,36,60,.96),rgba(7,21,37,.98));
      border:1px solid rgba(96,165,250,.22);border-radius:var(--radius);
      padding:22px;box-shadow:var(--shadow);min-width:0;
    }
    .panel-header{display:flex;justify-content:space-between;align-items:flex-start;gap:16px;margin-bottom:12px}
    .panel-title{margin:0;font-size:22px;font-weight:900;letter-spacing:-.04em}
    .panel-sub{color:#9fc3eb;font-weight:800;font-size:13px;text-align:right}
    #lineChart{min-height:485px}
    #donutChart{min-height:360px}
    .legend-list{display:grid;gap:10px;margin-top:8px}
    .legend-item{
      display:grid;grid-template-columns:1fr auto auto;gap:14px;align-items:center;
      padding:12px 14px;border:1px solid rgba(96,165,250,.2);border-radius:14px;background:rgba(5,14,27,.44);
      font-size:13px;font-weight:900;
    }
    .legend-name{display:flex;align-items:center;gap:10px;min-width:0}
    .dot{width:11px;height:11px;border-radius:50%;flex:0 0 auto;background:var(--blue1)}
    .legend-value{color:#dbeafe;white-space:nowrap}
    .legend-pct{color:#7dd3fc;white-space:nowrap}
    .hint{margin-top:18px;color:#85a7cf;font-size:12px;font-weight:700;line-height:1.5}
    .empty{display:none;margin-top:18px;border:1px dashed rgba(125,211,252,.45);border-radius:18px;padding:18px;color:#bfdbfe;background:rgba(14,165,233,.07);font-weight:700}
    @media(max-width:1100px){.cards{grid-template-columns:repeat(2,1fr)}.grid{grid-template-columns:1fr}.filters{grid-template-columns:1fr 1fr}}
    @media(max-width:760px){
      .topbar{padding:20px 16px}.header-row{align-items:flex-start;flex-direction:column}.actions{width:100%;justify-content:stretch}.actions button,.actions .file-btn{flex:1;text-align:center}
      .logo{width:54px;height:54px;border-radius:17px;font-size:28px}main{padding:22px 16px 34px}.filters,.range-duo,.cards{grid-template-columns:1fr}.filter-card:last-child{grid-column:auto}
      .metric{min-height:128px}.grid{gap:14px}.panel{padding:16px}.panel-header{flex-direction:column}.panel-sub{text-align:left}#lineChart{min-height:390px}.legend-item{grid-template-columns:1fr;gap:6px}.legend-value,.legend-pct{padding-left:21px}
    }
  </style>
</head>
<body>
  <header class="topbar">
    <div class="header-row">
      <div class="brand">
        <div class="logo">C</div>
        <div>
          <div class="kicker">Cobreflex</div>
          <h1>Dashboard de Desempenho das Filiais</h1>
        </div>
      </div>
      <div class="actions">
        <button id="clearBtn">Limpar filtros</button>
      </div>
    </div>
    <div class="filters">
      <div class="filter-card">
        <label>Período</label>
        <div class="range-duo">
          <input type="date" id="startDate" />
          <input type="date" id="endDate" />
        </div>
      </div>
      <div class="filter-card">
        <label>Filial</label>
        <div class="multi-select" id="branchMulti">
          <button type="button" class="multi-btn" id="branchBtn">Todas as filiais</button>
          <div class="multi-menu" id="branchMenu">
            <label class="multi-option"><input type="checkbox" value="0114" checked>0114 - Lapa</label>
            <label class="multi-option"><input type="checkbox" value="0109" checked>0109 - Sorocaba</label>
            <label class="multi-option"><input type="checkbox" value="0104" checked>0104 - Joinville</label>
            <label class="multi-option"><input type="checkbox" value="0116" checked>0116 - Praia Grande</label>
            <div class="multi-actions">
              <button type="button" id="selectAllBranches">Todas</button>
              <button type="button" id="clearBranches">Limpar</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <main>
    <h2 class="section-title">Visão geral</h2>
    <div class="period-label" id="periodLabel">Carregando período...</div>

    <section class="cards">
      <div class="metric"><div class="tag">R$</div><div class="metric-title">Faturamento total</div><div class="metric-value" id="totalRevenue">R$ 0</div><div class="metric-foot" id="totalFoot"></div></div>
      <div class="metric"><div class="tag">MÊS</div><div class="metric-title">Média mensal</div><div class="metric-value" id="avgMonthly">R$ 0</div><div class="metric-foot" id="avgFoot"></div></div>
      <div class="metric"><div class="tag">DIA</div><div class="metric-title">Média diária</div><div class="metric-value" id="avgDaily">R$ 0</div><div class="metric-foot" id="dailyFoot"></div></div>
    </section>

    <section class="grid">
      <div class="panel">
        <div class="panel-header">
          <h3 class="panel-title">Evolução mensal por filial</h3>
          <div class="panel-sub" id="lineInfo">0 meses • 4 filiais</div>
        </div>
        <div id="lineChart"></div>
        <div class="empty" id="emptyLine">Sem dados para o período selecionado.</div>
      </div>
      <div class="panel">
        <div class="panel-header">
          <h3 class="panel-title">Participação no faturamento</h3>
        </div>
        <div id="donutChart"></div>
        <div class="legend-list" id="donutLegend"></div>
      </div>
    </section>
  </main>

